<div class="row justify-content-center">
  <div class="col-lg-8 col-xl-7">
    <div class="card-premium p-4">
      <div class="mb-4">
        <a href="/guru" class="btn btn-premium btn-sm p-1 px-3 border border-2 text-decoration-none mb-3 d-inline-flex align-items-center gap-1" style="font-size: 0.85rem; color: var(--purple);">
          <i class="fa-solid fa-arrow-left"></i> Kembali ke Daftar
        </a>
        <h4 class="fw-bold mb-1" style="color: var(--purple-dark);">Perbarui Data Guru</h4>
        <p class="text-muted mb-0 small">Ubah informasi pengajar. Kosongkan kolom Kata Sandi jika tidak ingin mengubah sandi.</p>
      </div>

      <form action="/guru/edit/<%= target._id %>?_method=PUT" method="POST" class="form-premium needs-validation" novalidate>
        <div class="row g-3">
          <!-- Nama -->
          <div class="col-12">
            <label for="nama" class="form-label fw-bold">Nama Lengkap Guru</label>
            <input type="text" class="form-control" id="nama" name="nama" value="<%= target.nama %>" required>
            <div class="invalid-feedback">Nama lengkap wajib diisi.</div>
          </div>

          <!-- Email -->
          <div class="col-md-6">
            <label for="email" class="form-label fw-bold">Alamat Email Resmi</label>
            <input type="email" class="form-control" id="email" name="email" value="<%= target.email %>" required>
            <div class="invalid-feedback">Email valid wajib diisi.</div>
          </div>

          <!-- Password -->
          <div class="col-md-6">
            <label for="password" class="form-label fw-bold">Kata Sandi Baru (Opsional)</label>
            <input type="password" class="form-control" id="password" name="password" placeholder="Biarkan kosong jika tetap" minlength="6">
            <div class="invalid-feedback">Kata sandi minimal 6 karakter.</div>
          </div>

          <!-- NIP -->
          <div class="col-md-6">
            <label for="nip" class="form-label fw-bold">NIP (Nomor Induk Pegawai)</label>
            <input type="text" class="form-control" id="nip" name="nip" value="<%= target.nip %>" required pattern="\d{18}">
            <div class="invalid-feedback">NIP wajib berupa 18 digit angka.</div>
          </div>

          <!-- Mata Pelajaran -->
          <div class="col-md-6">
            <label for="mapel" class="form-label fw-bold">Mata Pelajaran Utama</label>
            <select class="form-select" id="mapel" name="mapel" required>
              <option value="Matematika" <%= target.mapel === 'Matematika' ? 'selected' : '' %>>Matematika</option>
              <option value="IPA" <%= target.mapel === 'IPA' ? 'selected' : '' %>>IPA (Sains)</option>
              <option value="IPS" <%= target.mapel === 'IPS' ? 'selected' : '' %>>IPS (Sosial)</option>
              <option value="Bahasa Indonesia" <%= target.mapel === 'Bahasa Indonesia' ? 'selected' : '' %>>Bahasa Indonesia</option>
              <option value="Informatika" <%= target.mapel === 'Informatika' ? 'selected' : '' %>>Informatika</option>
            </select>
            <div class="invalid-feedback">Silakan tentukan mata pelajaran diampu.</div>
          </div>

          <!-- Jenjang -->
          <div class="col-12">
            <label for="jenjang" class="form-label fw-bold">Jenjang Ajar</label>
            <input type="text" class="form-control" id="jenjang" name="jenjang" value="<%= target.jenjang %>" required>
            <div class="invalid-feedback">Jenjang ajar wajib diisi.</div>
          </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
          <a href="/guru" class="btn btn-premium btn-light border border-2">Batal</a>
          <button type="submit" class="btn btn-premium btn-premium-primary" style="background: linear-gradient(135deg, var(--teal) 0%, #35c093 100%);">
            <i class="fa-solid fa-floppy-disk me-1"></i> Perbarui Data
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  (function () {
    'use strict'
    var forms = document.querySelectorAll('.needs-validation')
    Array.prototype.slice.call(forms)
      .forEach(function (form) {
        form.addEventListener('submit', function (event) {
          if (!form.checkValidity()) {
            event.preventDefault()
            event.stopPropagation()
          }
          form.classList.add('was-validated')
        }, false)
      })
  })()
</script>
