<div class="row justify-content-center">
  <div class="col-lg-8 col-xl-7">
    <div class="card-premium p-4">
      <div class="mb-4">
        <a href="/siswa" class="btn btn-premium btn-sm p-1 px-3 border border-2 text-decoration-none mb-3 d-inline-flex align-items-center gap-1" style="font-size: 0.85rem; color: var(--purple);">
          <i class="fa-solid fa-arrow-left"></i> Kembali ke Daftar
        </a>
        <h4 class="fw-bold mb-1" style="color: var(--purple-dark);">Perbarui Data Siswa</h4>
        <p class="text-muted mb-0 small">Ubah informasi siswa. Kosongkan kolom Kata Sandi jika tidak ingin mengubah sandi.</p>
      </div>

      <form action="/siswa/edit/<%= target._id %>?_method=PUT" method="POST" class="form-premium needs-validation" novalidate>
        <div class="row g-3">
          <!-- Nama -->
          <div class="col-12">
            <label for="nama" class="form-label fw-bold">Nama Lengkap Siswa</label>
            <input type="text" class="form-control" id="nama" name="nama" value="<%= target.nama %>" required>
            <div class="invalid-feedback">Nama lengkap wajib diisi.</div>
          </div>

          <!-- Email -->
          <div class="col-md-6">
            <label for="email" class="form-label fw-bold">Alamat Email</label>
            <input type="email" class="form-control" id="email" name="email" value="<%= target.email %>" required>
            <div class="invalid-feedback">Email valid wajib diisi.</div>
          </div>

          <!-- Password -->
          <div class="col-md-6">
            <label for="password" class="form-label fw-bold">Kata Sandi Baru (Opsional)</label>
            <input type="password" class="form-control" id="password" name="password" placeholder="Biarkan kosong jika tetap" minlength="6">
            <div class="invalid-feedback">Kata sandi minimal 6 karakter.</div>
          </div>

          <!-- NISN -->
          <div class="col-md-6">
            <label for="nisn" class="form-label fw-bold">NISN (Nomor Induk Siswa Nasional)</label>
            <input type="text" class="form-control" id="nisn" name="nisn" value="<%= target.nisn %>" required pattern="\d{10}">
            <div class="invalid-feedback">NISN wajib berupa 10 digit angka.</div>
          </div>

          <!-- Kelas -->
          <div class="col-md-6">
            <label for="kelas" class="form-label fw-bold">Pilih Kelas</label>
            <select class="form-select" id="kelas" name="kelas" required>
              <option value="6A" <%= target.kelas === '6A' ? 'selected' : '' %>>Kelas 6A</option>
              <option value="6B" <%= target.kelas === '6B' ? 'selected' : '' %>>Kelas 6B</option>
              <option value="6C" <%= target.kelas === '6C' ? 'selected' : '' %>>Kelas 6C</option>
              <option value="6D" <%= target.kelas === '6D' ? 'selected' : '' %>>Kelas 6D</option>
            </select>
            <div class="invalid-feedback">Silakan pilih kelas siswa.</div>
          </div>

          <!-- Sekolah -->
          <div class="col-12">
            <label for="sekolah" class="form-label fw-bold">Nama Sekolah asal</label>
            <input type="text" class="form-control" id="sekolah" name="sekolah" value="<%= target.sekolah %>" required>
            <div class="invalid-feedback">Nama sekolah wajib diisi.</div>
          </div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
          <a href="/siswa" class="btn btn-premium btn-light border border-2">Batal</a>
          <button type="submit" class="btn btn-premium btn-premium-primary">
            <i class="fa-solid fa-floppy-disk me-1"></i> Perbarui Data
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  (function () {
    'use strict'
    var forms = document.querySelectorAll('.needs-validation')
    Array.prototype.slice.call(forms)
      .forEach(function (form) {
        form.addEventListener('submit', function (event) {
          if (!form.checkValidity()) {
            event.preventDefault()
            event.stopPropagation()
          }
          form.classList.add('was-validated')
        }, false)
      })
  })()
</script>
