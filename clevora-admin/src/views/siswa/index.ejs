<div class="card-premium p-4">
  
  <div class="d-md-flex align-items-center justify-content-between mb-4">
    <div>
      <h4 class="fw-bold mb-1" style="color: var(--purple-dark);">Daftar Siswa</h4>
      <p class="text-muted mb-0 small">Kelola data murid, jenjang, NISN, serta status verifikasi akun.</p>
    </div>
    <div class="mt-3 mt-md-0 d-flex gap-2">
      <!-- Filter kelas -->
      <select id="kelasFilter" class="form-select border-2" style="border-radius: 12px; width: 160px; font-weight: 600; color: var(--purple);">
        <option value="">Semua Kelas</option>
        <option value="6A">Kelas 6A</option>
        <option value="6B">Kelas 6B</option>
        <option value="6C">Kelas 6C</option>
        <option value="6D">Kelas 6D</option>
      </select>
      <a href="/siswa/tambah" class="btn btn-premium btn-premium-primary">
        <i class="fa-solid fa-plus me-1"></i> Tambah Siswa
      </a>
    </div>
  </div>

  <div class="table-responsive">
    <table id="siswaTable" class="table table-borderless align-middle table-premium w-100">
      <thead class="table-light text-muted" style="font-size: 0.85rem; font-weight: 700;">
        <tr>
          <th>NO</th>
          <th>NAMA LENGKAP</th>
          <th>NISN</th>
          <th>KELAS</th>
          <th>EMAIL</th>
          <th>STATUS AKUN</th>
          <th class="text-end">AKSI</th>
        </tr>
      </thead>
      <tbody>
        <% if (siswa && siswa.length > 0) { %>
          <% siswa.forEach((item, index) => { %>
            <tr data-kelas="<%= item.kelas %>">
              <td class="text-muted"><%= index + 1 %></td>
              <td class="fw-bold" style="color: var(--purple-dark);"><%= item.nama %></td>
              <td class="fw-semibold"><%= item.nisn || '-' %></td>
              <td><span class="badge badge-premium badge-purple"><%= item.kelas || 'N/A' %></span></td>
              <td class="text-muted"><%= item.email %></td>
              <td>
                <% if (item.is_verified) { %>
                  <span class="badge badge-premium badge-teal"><i class="fa-solid fa-circle-check me-1"></i> Terverifikasi</span>
                <% } else { %>
                  <span class="badge badge-premium badge-amber"><i class="fa-solid fa-clock me-1"></i> Pending OTP</span>
                <% } %>
              </td>
              <td class="text-end">
                <div class="d-flex justify-content-end gap-2">
                  <a href="/siswa/edit/<%= item._id %>" class="btn btn-sm btn-outline-primary border-0 rounded-3 p-2 px-3" style="background-color: rgba(83, 74, 183, 0.05); color: var(--purple);">
                    <i class="fa-solid fa-pen-to-square"></i>
                  </a>
                  <button type="button" class="btn btn-sm btn-outline-danger border-0 rounded-3 p-2 px-3" style="background-color: var(--error-light); color: var(--error);" onclick="confirmDelete('<%= item._id %>', '<%= item.nama %>')">
                    <i class="fa-solid fa-trash-can"></i>
                  </button>
                  <form id="delete-form-<%= item._id %>" action="/siswa/delete/<%= item._id %>?_method=DELETE" method="POST" class="d-none"></form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // Initialize DataTables
    const table = $('#siswaTable').DataTable({
      responsive: true,
      dom: '<"d-flex align-items-center justify-content-between mb-3"lfr>t<"d-flex align-items-center justify-content-between mt-3"ip>',
      language: {
        search: "Cari Siswa:",
        lengthMenu: "Tampilkan _MENU_ data",
        info: "Menampilkan _START_ sampai _END_ dari _TOTAL_ siswa",
        infoEmpty: "Menampilkan 0 sampai 0 dari 0 siswa",
        paginate: {
          next: "<i class='fa-solid fa-chevron-right'></i>",
          previous: "<i class='fa-solid fa-chevron-left'></i>"
        }
      }
    });

    // Custom filtering by Class
    $('#kelasFilter').on('change', function() {
      const selectedClass = this.value;
      if (selectedClass) {
        // filter table rows by column 3 (Class badge)
        table.column(3).search('^' + selectedClass + '$', true, false).draw();
      } else {
        table.column(3).search('').draw();
      }
    });
  });

  function confirmDelete(id, name) {
    Swal.fire({
      title: 'Apakah Anda yakin?',
      text: `Data siswa "${name}" akan dihapus permanen dari sistem Clevora.`,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#E24B4A',
      cancelButtonColor: '#4B5563',
      confirmButtonText: 'Ya, Hapus!',
      cancelButtonText: 'Batal',
      background: '#fff',
      customClass: {
        popup: 'rounded-4 border-0'
      }
    }).then((result) => {
      if (result.isConfirmed) {
        document.getElementById(`delete-form-${id}`).submit();
      }
    });
  }
</script>
