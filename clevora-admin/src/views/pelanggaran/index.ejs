<div class="card-premium p-4">
  
  <div class="d-md-flex align-items-center justify-content-between mb-4">
    <div>
      <h4 class="fw-bold mb-1" style="color: var(--error);"><i class="fa-solid fa-shield-halved me-1"></i> Log Pelanggaran CV Proctoring</h4>
      <p class="text-muted mb-0 small">Sistem AI FaceNet mendeteksi pelanggaran siswa secara real-time selama ujian berlangsung.</p>
    </div>
    <div class="mt-3 mt-md-0 d-flex gap-2">
      <!-- Filter kelas -->
      <select id="kelasFilter" class="form-select border-2" style="border-radius: 12px; width: 150px;">
        <option value="">Semua Kelas</option>
        <option value="6A">Kelas 6A</option>
        <option value="6B">Kelas 6B</option>
        <option value="6C">Kelas 6C</option>
        <option value="6D">Kelas 6D</option>
      </select>
    </div>
  </div>

  <div class="table-responsive">
    <table id="pelanggaranTable" class="table table-borderless align-middle table-premium w-100">
      <thead class="table-light text-muted" style="font-size: 0.85rem; font-weight: 700;">
        <tr>
          <th>NAMA SISWA</th>
          <th>KELAS</th>
          <th>UJIAN / KUIS</th>
          <th>JUMLAH PERINGATAN</th>
          <th>BERAKHIR PAKSA</th>
          <th>TANGGAL DETEKSI</th>
          <th class="text-end">AKSI</th>
        </tr>
      </thead>
      <tbody>
        <% if (results && results.length > 0) { %>
          <% results.forEach(item => { %>
            <tr data-kelas="<%= item.siswa ? item.siswa.kelas : '' %>" style="border-left: 4px solid var(--error); background-color: rgba(226, 75, 74, 0.01);">
              <td class="fw-bold" style="color: var(--purple-dark);"><%= item.siswa ? item.siswa.nama : 'N/A' %></td>
              <td><span class="badge badge-premium badge-purple"><%= item.siswa ? item.siswa.kelas : 'N/A' %></span></td>
              <td class="fw-semibold"><%= item.kuis ? item.kuis.judul : 'N/A' %></td>
              <td>
                <span class="badge badge-premium badge-error fw-bold fs-6 py-1 px-3">
                  <i class="fa-solid fa-triangle-exclamation me-1"></i> <%= item.jumlah_peringatan %> Peringatan
                </span>
              </td>
              <td>
                <% if (item.berakhir_paksa) { %>
                  <span class="badge badge-premium badge-error"><i class="fa-solid fa-lock me-1"></i> Ya, Diblokir AI</span>
                <% } else { %>
                  <span class="badge badge-premium badge-teal"><i class="fa-solid fa-lock-open me-1"></i> Tidak</span>
                <% } %>
              </td>
              <td class="text-muted"><%= new Date(item.createdAt).toLocaleString('id-ID') %></td>
              <td class="text-end">
                <button type="button" class="btn btn-premium btn-sm btn-outline-danger p-1 px-3 border border-2 border-danger text-danger bg-white" 
                        onclick="showDetailTimeline('<%= item.siswa ? item.siswa.nama : 'N/A' %>', '<%= item.siswa ? item.siswa.kelas : 'N/A' %>', '<%= item.kuis ? item.kuis.judul : 'N/A' %>', '<%= item.jumlah_peringatan %>', '<%= item.berakhir_paksa %>', '<%= JSON.stringify(item.log_pelanggaran) %>')">
                  Lihat Detail
                </button>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <!-- Seed mock data if empty -->
          <tr data-kelas="6A" style="border-left: 4px solid var(--error); background-color: rgba(226, 75, 74, 0.01);">
            <td class="fw-bold" style="color: var(--purple-dark);">Budi Santoso</td>
            <td><span class="badge badge-premium badge-purple">6A</span></td>
            <td class="fw-semibold">Kuis Aljabar Dasar</td>
            <td>
              <span class="badge badge-premium badge-error fw-bold fs-6 py-1 px-3">
                <i class="fa-solid fa-triangle-exclamation me-1"></i> 3 Peringatan
              </span>
            </td>
            <td><span class="badge badge-premium badge-error"><i class="fa-solid fa-lock me-1"></i> Ya, Diblokir AI</span></td>
            <td class="text-muted">30/05/2026, 18:30:15</td>
            <td class="text-end">
              <button type="button" class="btn btn-premium btn-sm btn-outline-danger p-1 px-3 border border-2 border-danger text-danger bg-white"
                      onclick="showDetailTimeline('Budi Santoso', '6A', 'Kuis Aljabar Dasar', '3', 'true', '[{&quot;jenis_pelanggaran&quot;:&quot;wajah_tidak_ada&quot;,&quot;timestamp&quot;:&quot;2026-05-30T18:25:00Z&quot;,&quot;screenshot_url&quot;:&quot;https://images.unsplash.com/photo-1544717297-fa95b6ee9643?w=500&quot;},{&quot;jenis_pelanggaran&quot;:&quot;menoleh&quot;,&quot;timestamp&quot;:&quot;2026-05-30T18:27:00Z&quot;,&quot;screenshot_url&quot;:&quot;https://images.unsplash.com/photo-1544717297-fa95b6ee9643?w=500&quot;},{&quot;jenis_pelanggaran&quot;:&quot;pindah_aplikasi&quot;,&quot;timestamp&quot;:&quot;2026-05-30T18:29:00Z&quot;,&quot;screenshot_url&quot;:&quot;https://images.unsplash.com/photo-1544717297-fa95b6ee9643?w=500&quot;}]')">
                Lihat Detail
              </button>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

</div>

<!-- Timeline Detail Modal -->
<div class="modal fade border-0" id="timelineModal" tabindex="-1" aria-labelledby="timelineModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 shadow-lg rounded-4">
      <div class="modal-header border-0 bg-danger text-white rounded-top-4 p-3 px-4 d-flex align-items-center justify-content-between">
        <h5 class="modal-title fw-bold" id="timelineModalLabel"><i class="fa-solid fa-shield-halved me-1"></i> Rincian Pelanggaran Proctoring</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <!-- Overview -->
        <div class="row g-3 mb-4 p-3 bg-light rounded-3">
          <div class="col-6 col-md-3">
            <small class="text-muted d-block font-semibold">NAMA SISWA</small>
            <strong id="modalSiswa" class="text-dark">Budi Santoso</strong>
          </div>
          <div class="col-6 col-md-3">
            <small class="text-muted d-block font-semibold">KELAS</small>
            <strong id="modalKelas" class="text-dark">6A</strong>
          </div>
          <div class="col-6 col-md-3">
            <small class="text-muted d-block font-semibold">UJIAN / KUIS</small>
            <strong id="modalKuis" class="text-dark">Kuis Aljabar Dasar</strong>
          </div>
          <div class="col-6 col-md-3">
            <small class="text-muted d-block font-semibold">BLOKIR AI</small>
            <span id="modalBlokir" class="badge badge-premium badge-error mt-1">Ya, Diblokir AI</span>
          </div>
        </div>

        <h6 class="fw-bold text-dark mb-3"><i class="fa-solid fa-timeline me-1"></i> Timeline Pelanggaran Terdeteksi</h6>
        <!-- Timeline Container -->
        <div class="timeline-container px-2" id="timelineList" style="max-height: 350px; overflow-y: auto;">
          <!-- Timeline items injected here -->
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const table = $('#pelanggaranTable').DataTable({
      responsive: true,
      dom: '<"d-flex align-items-center justify-content-between mb-3"lfr>t<"d-flex align-items-center justify-content-between mt-3"ip>',
      language: {
        search: "Cari Pelanggaran:",
        lengthMenu: "Tampilkan _MENU_ data",
        info: "Menampilkan _START_ sampai _END_ dari _TOTAL_ log pelanggaran"
      }
    });

    $('#kelasFilter').on('change', function() {
      const selectedClass = this.value;
      if (selectedClass) {
        table.column(1).search('^' + selectedClass + '$', true, false).draw();
      } else {
        table.column(1).search('').draw();
      }
    });
  });

  function showDetailTimeline(siswa, kelas, kuis, warnings, blocked, logStr) {
    document.getElementById("modalSiswa").innerText = siswa;
    document.getElementById("modalKelas").innerText = kelas;
    document.getElementById("modalKuis").innerText = kuis;
    
    const isBlocked = blocked === "true" || blocked === true;
    const blockBadge = document.getElementById("modalBlokir");
    if (isBlocked) {
      blockBadge.className = "badge badge-premium badge-error mt-1";
      blockBadge.innerHTML = '<i class="fa-solid fa-lock me-1"></i> Ya';
    } else {
      blockBadge.className = "badge badge-premium badge-teal mt-1";
      blockBadge.innerHTML = '<i class="fa-solid fa-lock-open me-1"></i> Tidak';
    }

    // Populate timeline list
    const timelineList = document.getElementById("timelineList");
    timelineList.innerHTML = "";

    try {
      const logs = JSON.parse(logStr);
      if (logs && logs.length > 0) {
        logs.forEach(log => {
          let label = "Pelanggaran";
          let icon = '<i class="fa-solid fa-circle-exclamation text-danger"></i>';
          
          if (log.jenis_pelanggaran === "wajah_tidak_ada") {
            label = "Wajah Tidak Terdeteksi";
            icon = '<i class="fa-solid fa-user-slash text-danger"></i>';
          } else if (log.jenis_pelanggaran === "multi_wajah") {
            label = "Terdeteksi Multi Wajah";
            icon = '<i class="fa-solid fa-users text-danger"></i>';
          } else if (log.jenis_pelanggaran === "menoleh") {
            label = "Mencurigakan: Menoleh / Menunduk";
            icon = '<i class="fa-solid fa-eye-slash text-danger"></i>';
          } else if (log.jenis_pelanggaran === "pindah_aplikasi") {
            label = "Keluar Ujian: Pindah Tab / Aplikasi";
            icon = '<i class="fa-solid fa-window-restore text-danger"></i>';
          }

          const timeStr = new Date(log.timestamp).toLocaleTimeString('id-ID');
          
          const item = document.createElement("div");
          item.className = "d-flex gap-3 mb-4 align-items-start border-bottom pb-3";
          item.innerHTML = `
            <div class="fs-4 bg-light rounded-3 p-2 d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
              ${icon}
            </div>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <h6 class="fw-bold text-dark mb-0">${label}</h6>
                <small class="text-muted fw-semibold"><i class="fa-regular fa-clock me-1"></i> ${timeStr}</small>
              </div>
              <p class="text-muted small mb-2">Tindakan tidak diizinkan terdeteksi oleh FaceNet Proctoring Engine.</p>
              ${log.screenshot_url ? `
                <div class="mt-2">
                  <a href="${log.screenshot_url}" target="_blank" class="d-inline-block">
                    <img src="${log.screenshot_url}" alt="Screenshot" class="rounded-3 shadow-sm" style="max-height: 120px; border: 2px solid var(--error);">
                  </a>
                </div>
              ` : ''}
            </div>
          `;
          timelineList.appendChild(item);
        });
      } else {
        timelineList.innerHTML = '<div class="text-center py-4 text-muted">Tidak ada log detail pelanggaran.</div>';
      }
    } catch (e) {
      console.error(e);
      timelineList.innerHTML = '<div class="text-center py-4 text-muted">Tidak ada log detail pelanggaran.</div>';
    }

    // Show modal
    const myModal = new bootstrap.Modal(document.getElementById('timelineModal'));
    myModal.show();
  }
</script>
