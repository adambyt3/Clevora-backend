<div class="container-fluid p-0 animate-fade-in">
  
  <% if (typeof warning !== 'undefined') { %>
    <div class="alert alert-warning border-0 shadow-sm rounded-3 mb-4 py-3 d-flex align-items-center gap-2">
      <i class="fa-solid fa-triangle-exclamation fs-5 text-warning"></i>
      <div>
        <strong class="d-block">Mode Offline</strong>
        <span class="small"><%= warning %></span>
      </div>
    </div>
  <% } %>

  <!-- Header -->
  <div class="d-md-flex align-items-center justify-content-between mb-4">
    <div>
      <h2 class="fw-bold mb-1" style="color: var(--purple-dark);">Selamat Datang, <%= admin ? admin.nama.split(' ')[0] : 'Admin' %>!</h2>
      <p class="text-muted mb-0">Berikut adalah ikhtisar performa akademik platform Clevora hari ini.</p>
    </div>
    <div class="mt-3 mt-md-0">
      <button class="btn btn-premium btn-premium-primary" onclick="window.location.reload();">
        <i class="fa-solid fa-arrows-rotate me-1"></i> Segarkan Data
      </button>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="row g-4 mb-4">
    <!-- Siswa -->
    <div class="col-sm-6 col-xl-3">
      <div class="card-premium card-stat card-stat-siswa h-100">
        <div class="stat-icon stat-icon-purple">
          <i class="fa-solid fa-user-graduate"></i>
        </div>
        <div class="stat-value text-purple"><%= stats.totalSiswa %></div>
        <div class="stat-label">Total Siswa Aktif</div>
      </div>
    </div>

    <!-- Guru -->
    <div class="col-sm-6 col-xl-3">
      <div class="card-premium card-stat card-stat-guru h-100">
        <div class="stat-icon stat-icon-teal">
          <i class="fa-solid fa-chalkboard-user"></i>
        </div>
        <div class="stat-value text-teal"><%= stats.totalGuru %></div>
        <div class="stat-label">Total Guru Terdaftar</div>
      </div>
    </div>

    <!-- Kuis -->
    <div class="col-sm-6 col-xl-3">
      <div class="card-premium card-stat card-stat-kuis h-100">
        <div class="stat-icon stat-icon-amber">
          <i class="fa-solid fa-circle-question"></i>
        </div>
        <div class="stat-value text-amber"><%= stats.totalKuis %></div>
        <div class="stat-label">Kuis Dibuat</div>
      </div>
    </div>

    <!-- Rerata Nilai -->
    <div class="col-sm-6 col-xl-3">
      <div class="card-premium card-stat card-stat-nilai h-100">
        <div class="stat-icon stat-icon-dark">
          <i class="fa-solid fa-award"></i>
        </div>
        <div class="stat-value text-purple-dark"><%= stats.rerataNilai %>%</div>
        <div class="stat-label">Rata-rata Nilai Platform</div>
      </div>
    </div>
  </div>

  <!-- Charts -->
  <div class="row g-4 mb-4">
    <!-- Rata-rata per kelas -->
    <div class="col-xl-6">
      <div class="card-premium p-4 h-100">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h5 class="fw-bold mb-0" style="color: var(--purple-dark);">Rerata Nilai Per Kelas</h5>
          <span class="badge badge-premium badge-purple">Akademik</span>
        </div>
        <div style="position: relative; height: 300px;">
          <canvas id="kelasChart"></canvas>
        </div>
      </div>
    </div>

    <!-- Tren Nilai -->
    <div class="col-xl-6">
      <div class="card-premium p-4 h-100">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h5 class="fw-bold mb-0" style="color: var(--purple-dark);">Tren Nilai 7 Hari Terakhir</h5>
          <span class="badge badge-premium badge-teal">Log Aktivitas</span>
        </div>
        <div style="position: relative; height: 300px;">
          <canvas id="trenChart"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Data Tables Row -->
  <div class="row g-4">
    <!-- Kuis Terbaru -->
    <div class="col-xl-6">
      <div class="card-premium p-4 h-100">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h5 class="fw-bold mb-0" style="color: var(--purple-dark);">Kuis Terbaru Dibuka</h5>
          <a href="/kuis" class="btn btn-premium btn-sm p-1 px-3 border border-2 text-decoration-none" style="font-size: 0.8rem; font-weight: 600; color: var(--purple);">Semua Kuis</a>
        </div>
        <div class="table-responsive">
          <table class="table table-borderless align-middle table-premium">
            <thead class="table-light rounded-3" style="font-size: 0.85rem; font-weight: 700; color: var(--gray-600);">
              <tr>
                <th>JUDUL KUIS</th>
                <th>MATA PELAJARAN</th>
                <th>KELAS</th>
              </tr>
            </thead>
            <tbody>
              <% if (stats.latestQuizzes && stats.latestQuizzes.length > 0) { %>
                <% stats.latestQuizzes.forEach(quiz => { %>
                  <tr>
                    <td class="fw-bold" style="color: var(--purple-dark);"><%= quiz.judul %></td>
                    <td><span class="badge badge-premium badge-purple"><%= quiz.mapel %></span></td>
                    <td><span class="badge badge-premium badge-teal"><%= quiz.kelas || 'Semua' %></span></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="3" class="text-center py-4 text-muted">Belum ada kuis yang dibuat.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Siswa Perlu Perhatian -->
    <div class="col-xl-6">
      <div class="card-premium p-4 h-100">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h5 class="fw-bold mb-0" style="color: var(--error);">Siswa Perlu Perhatian</h5>
          <span class="badge badge-premium badge-error"><i class="fa-solid fa-triangle-exclamation me-1"></i> Rerata < 70</span>
        </div>
        <div class="table-responsive">
          <table class="table table-borderless align-middle table-premium">
            <thead class="table-light rounded-3" style="font-size: 0.85rem; font-weight: 700; color: var(--gray-600);">
              <tr>
                <th>NAMA SISWA</th>
                <th>KELAS</th>
                <th>KUIS</th>
                <th>SKOR</th>
              </tr>
            </thead>
            <tbody>
              <% if (stats.underperforming && stats.underperforming.length > 0) { %>
                <% stats.underperforming.forEach(item => { %>
                  <tr style="border-left: 4px solid var(--error);">
                    <td class="fw-bold" style="color: var(--purple-dark);"><%= item.siswa ? item.siswa.nama : 'N/A' %></td>
                    <td><span class="badge badge-premium badge-purple"><%= item.siswa ? item.siswa.kelas : 'N/A' %></span></td>
                    <td class="text-truncate" style="max-width: 150px;"><%= item.kuis ? item.kuis.judul : 'N/A' %></td>
                    <td><span class="badge badge-premium badge-error fw-bold"><%= item.nilai %>%</span></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="4" class="text-center py-4 text-muted" style="background-color: var(--teal-light); color: var(--teal); border-radius: 12px;">
                    <i class="fa-solid fa-circle-check me-1 fs-5"></i> Semua siswa memiliki nilai di atas rata-rata kelulusan!
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Charts Script -->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Kelas Average Chart
    const ctxKelas = document.getElementById('kelasChart').getContext('2d');
    new Chart(ctxKelas, {
      type: 'bar',
      data: {
        labels: ['Kelas 6A', 'Kelas 6B', 'Kelas 6C', 'Kelas 6D'],
        datasets: [{
          label: 'Nilai Rata-rata',
          data: [82.4, 76.8, 88.5, 71.2],
          backgroundColor: [
            'rgba(83, 74, 183, 0.85)',
            'rgba(29, 158, 117, 0.85)',
            'rgba(239, 159, 39, 0.85)',
            'rgba(226, 75, 74, 0.85)'
          ],
          borderColor: [
            '#534AB7',
            '#1D9E75',
            '#EF9F27',
            '#E24B4A'
          ],
          borderWidth: 2,
          borderRadius: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: {
            beginAtZero: true,
            max: 100,
            grid: { color: 'rgba(0,0,0,0.03)' }
          },
          x: { grid: { display: false } }
        }
      }
    });

    // 2. 7 Days Trend Chart
    const ctxTren = document.getElementById('trenChart').getContext('2d');
    new Chart(ctxTren, {
      type: 'line',
      data: {
        labels: ['Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu', 'Minggu'],
        datasets: [{
          label: 'Skor Rata-rata Harian',
          data: [78, 82, 80, 85, 84, 89, 88],
          fill: true,
          backgroundColor: 'rgba(83, 74, 183, 0.1)',
          borderColor: '#534AB7',
          borderWidth: 3,
          tension: 0.4,
          pointBackgroundColor: '#534AB7',
          pointHoverRadius: 7
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: {
            min: 60,
            max: 100,
            grid: { color: 'rgba(0,0,0,0.03)' }
          },
          x: { grid: { display: false } }
        }
      }
    });
  });
</script>
